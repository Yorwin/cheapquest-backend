# Copy this file to .env (gitignored) and fill in real values.
# These env vars are resolved by application.properties via ${VAR_NAME}.

# CheapShark (no key required)

# RAWG
RAWG_API_KEY=your_rawg_api_key_here

# DeepL
DEEPL_API_KEY=your_deepl_api_key_here

# Firebase
FIREBASE_PROJECT_ID=your_project_id_here
FIREBASE_CREDENTIALS_PATH=/absolute/path/to/firebase-credentials.json

# Admin endpoint
ADMIN_REFRESH_TOKEN=a_long_random_token_here
